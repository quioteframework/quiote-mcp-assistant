{
    "name": "quioteframework/quiote-mcp-assistant",
    "description": "MCP server giving AI agents authoritative knowledge of, and read-only/scaffolding access to, Quiote applications.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "quioteframework/quiote": "^1.2",
        "quioteframework/mcp": "^1.2",
        "mcp/sdk": "^0.6.0"
    },
    "autoload": {
        "psr-4": {
            "QuioteMcpAssistant\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QuioteMcpAssistant\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/quiote-assistant"
    ],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "quioteframework/phptal": "^1.2",
        "quioteframework/xslt": "^1.2",
        "quioteframework/twig": "^1.2"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --configuration=phpstan.neon"
    }
}
